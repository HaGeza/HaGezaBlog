# Default recipe
default:
    @just --list

# Build one or all WASM simulations
#   just wasm                  <- builds all binaries in the workspace
#   just wasm electro_magnetic <- builds only that binary
wasm sim="":
    #!/usr/bin/env bash
    set -e
    
    mkdir -p ../app/static/wasm

    if [ -z "{{sim}}" ]; then
        echo "Building all binaries..."
        cargo build --release --target wasm32-unknown-unknown
        
        find target/wasm32-unknown-unknown/release -maxdepth 1 -name "*.wasm" -exec cp {} ../app/static/wasm/ \;
        echo "Successfully copied all WASM files to ../app/static/wasm/"
    else
        echo "Building simulation: {{sim}}..."
        cargo build --release --target wasm32-unknown-unknown --bin {{sim}}
        cp target/wasm32-unknown-unknown/release/{{sim}}.wasm ../app/static/wasm/
        echo "Successfully copied {{sim}}.wasm to ../app/static/wasm/"
    fi

# Clean build artifacts
clean:
    cargo clean
    rm -rf ../app/static/wasm/*.wasm
